# Maintainer: Open Quantum Platform developers

_realname=openqp
_repo_root="${startdir:-$PWD}/../../.."
pkgbase=mingw-w64-${_realname}
pkgname=("${MINGW_PACKAGE_PREFIX}-${_realname}")
pkgver=$(sed -n 's/^version[[:space:]]*=[[:space:]]*"\([^"]*\)"/\1/p' "${_repo_root}/pyproject.toml")
pkgrel=1
pkgdesc="Python bindings and command-line launcher for the Open Quantum Platform"
arch=("any")
mingw_arch=("ucrt64")
url="https://github.com/Open-Quantum-Platform/openqp"
license=("GPL-3.0-or-later")
install="${_realname}.install"
depends=(
  "${MINGW_PACKAGE_PREFIX}-python"
  "${MINGW_PACKAGE_PREFIX}-python-cffi"
  "${MINGW_PACKAGE_PREFIX}-python-numpy"
  "${MINGW_PACKAGE_PREFIX}-python-scipy"
)
makedepends=(
  "${MINGW_PACKAGE_PREFIX}-gcc"
  "${MINGW_PACKAGE_PREFIX}-gcc-fortran"
  "${MINGW_PACKAGE_PREFIX}-cmake"
  "${MINGW_PACKAGE_PREFIX}-ninja"
  "${MINGW_PACKAGE_PREFIX}-python-build"
  "${MINGW_PACKAGE_PREFIX}-python-installer"
  "${MINGW_PACKAGE_PREFIX}-python-scikit-build-core"
  "${MINGW_PACKAGE_PREFIX}-python-setuptools"
  "${MINGW_PACKAGE_PREFIX}-python-wheel"
)
optdepends=(
  "${MINGW_PACKAGE_PREFIX}-python-pip: install basis_set_exchange and geometric until they are packaged for MSYS2"
)
source=()
sha256sums=()

build() {
  local _srcdir="${_repo_root}"

  export CC="${CC:-gcc}"
  export CXX="${CXX:-g++}"
  export FC="${FC:-gfortran}"
  export CMAKE_BUILD_PARALLEL_LEVEL="${CMAKE_BUILD_PARALLEL_LEVEL:-$(nproc)}"
  export CMAKE_ARGS="${CMAKE_ARGS:-} -DUSE_LIBINT=OFF -DENABLE_OPENMP=ON -DENABLE_OPENTRAH=OFF -DLINALG_LIB=netlib -DLINALG_LIB_INT64=ON -DOQP_EXTERNALS_ROOT=${srcdir}/openqp-externals"

  rm -rf "${srcdir}/dist"
  cd "${_srcdir}"
  python -m build --wheel --no-isolation --outdir "${srcdir}/dist"
}

package() {
  local _wheel
  _wheel="$(find "${srcdir}/dist" -maxdepth 1 -type f -name '*.whl' | head -n 1)"
  if [[ -z "${_wheel}" ]]; then
    echo "No OpenQP wheel found in ${srcdir}/dist" >&2
    return 1
  fi

  python -m installer --destdir="${pkgdir}" "${_wheel}"
  install -Dm644 "${_repo_root}/LICENSE" "${pkgdir}${MINGW_PREFIX}/share/licenses/${_realname}/LICENSE"
}
